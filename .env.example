# Optional: API URL when running Backend separately (Phase 5 Frontend)
# CHAT_API_URL=http://localhost:8000

# Optional: Groq API key for Phase 3 LLM-based answer generation (preferred if set)
# Get a key at https://console.groq.com/ — then copy .env.example to .env and set:
# GROQ_API_KEY=your_key_here

# Optional: xAI Grok API key (used if GROQ_API_KEY is not set)
# Get a key at https://console.x.ai/
# XAI_API_KEY=your_key_here
